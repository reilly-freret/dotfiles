[
    {
        "context": "Editor && vim_mode == normal",
        "bindings": {
            "j": "vim::Down",
            "k": "vim::Up",
            "T T": "pane::CloseActiveItem",
            "space": [
                "workspace::SendKeystrokes",
                "a space left"
            ]
        }
    },
    {
        "context": "Editor && vim_mode == insert && !menu",
        "bindings": {
            "j k": "vim::SwitchToNormalMode"
        }
    },
    {
        "context": "Editor && vim_mode == insert && menu",
        "bindings": {
            "j k": [
                "workspace::SendKeystrokes",
                "escape escape"
            ]
        }
    },
    {
        "context": "vim_mode == visual",
        "bindings": {
            "shift-s": ["vim::PushAddSurrounds", {}]
        }
    },
    {
        "context": "Editor",
        "bindings": {
            "ctrl-m r": "pane::SplitAndMoveRight"
        }
    },
    {
        "context": "VimControl && !menu && vim_operator != i",
        "bindings": {
            ")": "vim::SentenceForward"
        }
    },
    {
        "context": "VimControl && !menu",
        "unbind": {
            ")": "vim::SentenceForward"
        }
    }
]
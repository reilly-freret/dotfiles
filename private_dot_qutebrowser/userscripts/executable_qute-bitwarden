    active.type.toLowerCase() === 'password' &&
    isVisible(active);

  if (activeIsPassword) {{
    setValue(active, passwordValue);
    log('filled active password field only');
    return true;
  }}

  const userEl = firstVisible(usernameSelector);
  const passEl = firstVisible(passwordSelector);
  log('smart fill', {{ hasUsername: !!userEl, hasPassword: !!passEl }});

  if (userEl && passEl) {{
    setValue(userEl, usernameValue);
    setValue(passEl, passwordValue);
    passEl.focus();
    return true;
  }}
  if (passEl) {{
    setValue(passEl, passwordValue);
    passEl.focus();
    return true;
  }}
  if (userEl) {{
    setValue(userEl, usernameValue);
    userEl.focus();
    return true;
  }}

  log('no visible login fields found for smart fill');
  return false;
}})();
"""
    js_payload = 'eval(atob({}));'.format(json.dumps(base64.b64encode(js.encode('utf-8')).decode('ascii')))
    qute_command('jseval --quiet -- ' + js_payload)


def fill_one_time_code_smart_once(code, debug=False):
    js = f"""
(() => {{
  const codeValue = {json.dumps(code)};
  const debug = {str(debug).lower()};
  const log = (...args) => {{
    if (debug) console.info('[qute-bitwarden]', ...args);
  }};

  const isVisible = (el) => {{
    if (!el) return false;
    const style = window.getComputedStyle(el);
    if (style.visibility === 'hidden' || style.display === 'none') return false;
    if (el.disabled || el.readOnly) return false;
    const rect = el.getBoundingClientRect();
    return rect.width > 0 && rect.height > 0;
  }};

  const setValue = (el, value) => {{
    el.focus();
    el.value = value;
    el.dispatchEvent(new Event('input', {{ bubbles: true }}));
    el.dispatchEvent(new Event('change', {{ bubbles: true }}));
  }};

  const active = document.activeElement;
  if (active && isVisible(active) && (active.tagName === 'INPUT' || active.tagName === 'TEXTAREA')) {{
    setValue(active, codeValue);
    log('filled active OTP field');
    return true;
  }}

  const otpSelector = [
    'input[autocomplete="one-time-code"]',
    'input[inputmode="numeric"]',
    'input[name*="otp" i]',
    'input[id*="otp" i]',
    'input[name*="code" i]',
    'input[id*="code" i]',
    'input[type="tel"]',
    'input[type="text"]'
  ].join(',');

  for (const el of document.querySelectorAll(otpSelector)) {{
    if (!isVisible(el)) continue;
    setValue(el, codeValue);
    log('filled visible OTP-like field');
    return true;
  }}

  log('no OTP input found');
  return false;
}})();
"""
    js_payload = 'eval(atob({}));'.format(json.dumps(base64.b64encode(js.encode('utf-8')).decode('ascii')))
    qute_command('jseval --quiet -- ' + js_payload)


def normalize_totp_code(value):
    if not value:
        return ''
    candidate = str(value).strip().replace(' ', '')
    if candidate == '[]':
        return ''
    # TOTP codes are numeric (usually 6 digits, sometimes 8 in some systems).
    if re.fullmatch(r'\d{6,8}', candidate):
        return candidate
    return ''


def main(arguments):
    socket_path = daemon_socket_path(arguments.daemon_socket)

    if arguments.daemon:
        return run_daemon(arguments)

    if arguments.start_daemon:
        start_daemon_process(arguments)
        if wait_for_daemon(socket_path, max(1.0, arguments.daemon_timeout)):
            info_message('qute-bitwarden daemon started')
            return ExitCodes.SUCCESS
        stderr('Could not start qute-bitwarden daemon')
        return ExitCodes.FAILURE

    if arguments.stop_daemon:
        try:
            daemon_request(socket_path, {'action': 'stop'}, arguments.daemon_timeout)
            info_message('qute-bitwarden daemon stopped')
            return ExitCodes.SUCCESS
        except Exception as error:
            stderr('Could not stop daemon: {}'.format(error))
            return ExitCodes.FAILURE

    if not arguments.url:
        argument_parser.print_help()
        return ExitCodes.FAILURE

    if arguments.totp_only and arguments.use_daemon:
        try:
            last_totp_response = daemon_request(
                socket_path,
                {'action': 'totp_last'},
                arguments.daemon_timeout,
            )
            if last_totp_response.get('ok'):
                last_totp_code = last_totp_response.get('totp', '')
                last_totp_code = normalize_totp_code(last_totp_code)
                if last_totp_code:
                    debug_message(
                        'Using TOTP from last selected entry "{}"'.format(last_totp_response.get('name', '')),
                        arguments.debug,
                    )
                    fill_one_time_code_smart_once(last_totp_code, arguments.debug)
                    if arguments.insert_mode:
                        qute_command('mode-enter insert')
                    return ExitCodes.SUCCESS
                debug_message(
                    'Last-selection TOTP failed: {}'.format(last_totp_response.get('error', 'empty result')),
                    arguments.debug,
                )
        except Exception as error:
            debug_message('Last-selection TOTP unavailable: {}'.format(error), arguments.debug)

    candidates = []
    daemon_active = False

    if arguments.use_daemon:
        try:
            response = daemon_request(
                socket_path,
                {'action': 'lookup', 'url': arguments.url, 'merge_candidates': arguments.merge_candidates},
                arguments.daemon_timeout,
            )
            if response.get('ok'):
                candidates = response.get('candidates', [])
                daemon_active = True
        except TimeoutError:
            debug_message('Daemon lookup timed out; falling back to direct mode', arguments.debug)
        except Exception:
            if arguments.daemon_autostart:
                debug_message('Daemon unavailable; starting background daemon', arguments.debug)
                start_daemon_process(arguments)
                if wait_for_daemon(socket_path, max(1.0, arguments.daemon_timeout)):
                    try:
                        response = daemon_request(
                            socket_path,
                            {'action': 'lookup', 'url': arguments.url, 'merge_candidates': arguments.merge_candidates},
                            arguments.daemon_timeout,
                        )
                        if response.get('ok'):
                            candidates = response.get('candidates', [])
                            daemon_active = True
                    except TimeoutError:
                        debug_message('Daemon timed out after autostart; falling back to direct mode', arguments.debug)

    if not daemon_active:
        for target in resolve_targets(arguments.url):
            target_candidates = json.loads(
                pass_(
                    target,
                    arguments.io_encoding,
                    arguments.auto_lock,
                    arguments.password_prompt_invocation,
                )
            )
            if not target_candidates:
                debug_message('No candidates for target {}'.format(target), arguments.debug)
                continue

            candidates = candidates + target_candidates
            debug_message('Found {} candidates for target {}'.format(len(target_candidates), target), arguments.debug)
            if not arguments.merge_candidates:
                break

    if not candidates:
        message = 'No pass candidates for URL {!r} found!'.format(arguments.url)
        if arguments.fail_on_no_candidates:
            stderr(message)
            return ExitCodes.NO_PASS_CANDIDATES
        info_message(message)
        return ExitCodes.SUCCESS

    if len(candidates) == 1:
        selection = candidates.pop()
    else:
        choices = ['{:s} | {:s}'.format(c['name'], c['login']['username']) for c in candidates]
        choice = dmenu(choices, arguments.dmenu_invocation, arguments.io_encoding)
        choice_tokens = choice.split('|')
        choice_name = choice_tokens[0].strip()
        choice_username = choice_tokens[1].strip()
        selection = next((c for (i, c) in enumerate(candidates)
                          if c['name'] == choice_name
                          and c['login']['username'] == choice_username),
                         None)

    # Nothing was selected, simply return
    if not selection:
        return ExitCodes.SUCCESS

    username = selection['login']['username']
    password = selection['login']['password']
    totp = selection['login']['totp']
    debug_message('Selected entry "{}"'.format(selection['name']), arguments.debug)
    if daemon_active:
        try:
            daemon_request(
                socket_path,
                {'action': 'remember_selection', 'id': selection['id'], 'name': selection['name']},
                arguments.daemon_timeout,
            )
        except Exception as error:
            debug_message('Could not remember selection in daemon: {}'.format(error), arguments.debug)

    if arguments.username_only:
        fake_key_raw(username)
    elif arguments.password_only:
        fake_key_raw(password)
    elif arguments.totp_only:
        # No point in moving it to the clipboard in this case
        daemon_totp_error = ''
        if daemon_active:
            daemon_totp_response = daemon_request(
                socket_path,
                {'action': 'totp', 'id': selection['id'], 'name': selection['name']},
                arguments.daemon_timeout,
            )
            totp_code = daemon_totp_response.get('totp', '')
            daemon_totp_error = daemon_totp_response.get('error', '')
            if not totp_code:
                debug_message(
                    'Daemon TOTP lookup failed: {}'.format(daemon_totp_error or 'empty result'),
                    arguments.debug,
                )
                # Fallback: direct CLI path in case daemon has stale state.
                totp_code = get_totp_code(
                    selection['id'],
                    selection['name'],
                    arguments.io_encoding,
                    arguments.auto_lock,
                    arguments.password_prompt_invocation,
                )
        else:
            totp_code = get_totp_code(
                selection['id'],
                selection['name'],
                arguments.io_encoding,
                arguments.auto_lock,
                arguments.password_prompt_invocation,
            )
        totp_code = normalize_totp_code(totp_code)
        if arguments.debug:
            debug_message(
                'TOTP-only candidate shape: len={} numeric={}'.format(
                    len(totp_code) if totp_code else 0,
                    bool(totp_code and totp_code.isdigit()),
                ),
                arguments.debug,
            )
        if not totp_code:
            info_message(
                'No TOTP code available for "{}"{}'.format(
                    selection['name'],
                    ' ({})'.format(daemon_totp_error) if daemon_totp_error else '',
                )
            )
        else:
            debug_message('Filling TOTP code into active field', arguments.debug)
            fill_one_time_code_smart_once(totp_code, arguments.debug)
    else:
        if arguments.watch_seconds > 0:
            # Optional dynamic-form mode for SPAs where fields are inserted later.
            debug_message('Injecting DOM watcher ({}s)'.format(arguments.watch_seconds), arguments.debug)
            fill_credentials_with_dom_watch(username, password, arguments.watch_seconds, arguments.debug)
        else:
            # Fast path for manual invocation when fields are already visible.
            # This handles both combined forms and two-step username->password flows.
            debug_message('Using immediate smart fill', arguments.debug)
            fill_credentials_smart_once(username, password, arguments.debug)

    if arguments.insert_mode:
        qute_command('mode-enter insert')

    # If it finds a TOTP code, it copies it to the clipboard,
    # which is the same behavior as the Firefox add-on.
    if not arguments.totp_only and arguments.totp:
        # The import is done here, to make pyperclip an optional dependency
        import pyperclip
        daemon_totp_error = ''
        if daemon_active:
            daemon_totp_response = daemon_request(
                socket_path,
                {'action': 'totp', 'id': selection['id'], 'name': selection['name']},
                arguments.daemon_timeout,
            )
            totp_code = daemon_totp_response.get('totp', '')
            daemon_totp_error = daemon_totp_response.get('error', '')
            if not totp_code:
                debug_message(
                    'Daemon TOTP lookup failed: {}'.format(daemon_totp_error or 'empty result'),
                    arguments.debug,
                )
                totp_code = get_totp_code(
                    selection['id'],
                    selection['name'],
                    arguments.io_encoding,
                    arguments.auto_lock,
                    arguments.password_prompt_invocation,
                )
        else:
            totp_code = get_totp_code(
                selection['id'],
                selection['name'],
                arguments.io_encoding,
                arguments.auto_lock,
                arguments.password_prompt_invocation,
            )
        totp_code = normalize_totp_code(totp_code)
        if totp_code:
            pyperclip.copy(totp_code)
        else:
            info_message(
                'No TOTP code available for "{}"{}'.format(
                    selection['name'],
                    ' ({})'.format(daemon_totp_error) if daemon_totp_error else '',
                )
            )

    return ExitCodes.SUCCESS


if __name__ == '__main__':
    arguments = argument_parser.parse_args()
    sys.exit(main(arguments))

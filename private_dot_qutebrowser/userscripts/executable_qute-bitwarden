def pass_(domain, encoding, auto_lock, password_prompt_invocation):
    session_key = get_session_key(auto_lock, password_prompt_invocation)
    process = subprocess.run(
        ['bw', 'list', 'items', '--nointeraction', '--session', session_key, '--url', domain],
        capture_output=True,
    )

    err = process.stderr.decode(encoding).strip()
    if err:
        msg = 'Bitwarden CLI returned for {:s} - {:s}'.format(domain, err)
        stderr(msg)

        if "Vault is locked" in err:
            stderr("Bitwarden Vault got locked, trying again with clean session")
            return pass_(domain, encoding, 0, password_prompt_invocation)

    if process.returncode:
        return '[]'

    out = process.stdout.decode(encoding).strip()

    return out


def get_totp_code(selection_id, domain_name, encoding, auto_lock, password_prompt_invocation):
    session_key = get_session_key(auto_lock, password_prompt_invocation)
    lookup_terms = [selection_id]
    if domain_name and domain_name not in lookup_terms:
        lookup_terms.append(domain_name)

    for term in lookup_terms:
        process = subprocess.run(
            ['bw', 'get', 'totp', '--nointeraction', '--session', session_key, term],
            capture_output=True,
        )
        err = process.stderr.decode(encoding).strip()
        if err and "Vault is locked" in err:
            stderr("Bitwarden Vault got locked, trying again with clean session")
            return get_totp_code(selection_id, domain_name, encoding, 0, password_prompt_invocation)
        if process.returncode == 0:
            out = process.stdout.decode(encoding).strip()
            if out and out != '[]':
                return out

    # One sync retry can fix stale status/cache issues.
    subprocess.run(
        ['bw', 'sync', '--nointeraction', '--session', session_key],
        capture_output=True,
    )
    for term in lookup_terms:
        process = subprocess.run(
            ['bw', 'get', 'totp', '--nointeraction', '--session', session_key, term],
            capture_output=True,
        )
        if process.returncode == 0:
            out = process.stdout.decode(encoding).strip()
            if out and out != '[]':
                return out

    return ''


def dmenu(items, invocation, encoding):
    command = shlex.split(invocation)
    process = subprocess.run(command, input='\n'.join(
        items).encode(encoding), stdout=subprocess.PIPE)
    return process.stdout.decode(encoding).strip()


def fake_key_raw(text):
    for character in text:
        # Escape all characters by default, space requires special handling
        sequence = '" "' if character == ' ' else r'\{}'.format(character)
        qute_command('fake-key {}'.format(sequence))


def _quote_for_qute_command(value):
    # qutebrowser command arguments use a shell-like parser; single-quote and
    # escape embedded single quotes.
    return "'" + value.replace("'", "'\"'\"'") + "'"


def debug_message(text, enabled):
    if not enabled:
        return
    message = '[qute-bitwarden] ' + text
    if 'QUTE_FIFO' in os.environ:
        qute_command('message-info ' + _quote_for_qute_command(message))
    else:
        stderr(message)


def info_message(text):
    if 'QUTE_FIFO' in os.environ:
        qute_command('message-info ' + _quote_for_qute_command(text))
    else:
        print(text)


def resolve_targets(url):
    extract_result = tldextract.extract(url)
    raw_targets = [
        extract_result.fqdn,
        (
            extract_result.top_domain_under_public_suffix
            if hasattr(extract_result, "top_domain_under_public_suffix")
            else extract_result.registered_domain
        ),
        extract_result.subdomain + "." + extract_result.domain,
        extract_result.domain,
        extract_result.ipv4,
    ]
    # Keep order stable while removing duplicates/empty values.
    targets = []
    for target in raw_targets:
        if target and target not in targets:
            targets.append(target)
    return targets


def daemon_socket_path(path):
    return os.path.expanduser(path)


def daemon_request(socket_path, payload, timeout):
    request = (json.dumps(payload) + '\n').encode('utf-8')
    with socket.socket(socket.AF_UNIX, socket.SOCK_STREAM) as client:
        # Keep connect timeout short-ish, but allow longer response times for
        # prompts like initial Bitwarden unlock in daemon mode.
        client.settimeout(timeout)
        client.connect(socket_path)
        client.sendall(request)
        client.settimeout(max(timeout, 60.0))
        chunks = []
        while True:
            data = client.recv(4096)
            if not data:
                break
            chunks.append(data)
            if b'\n' in data:
                break
    if not chunks:
        raise RuntimeError('Empty response from daemon')
    line = b''.join(chunks).split(b'\n', 1)[0]
    return json.loads(line.decode('utf-8'))


def start_daemon_process(arguments):
    socket_path = daemon_socket_path(arguments.daemon_socket)
    command = [
        sys.executable,
        os.path.abspath(__file__),
        '--daemon',
        '--daemon-socket',
        socket_path,
        '--password-prompt-invocation',
        arguments.password_prompt_invocation,
        '--io-encoding',
        arguments.io_encoding,
        '--auto-lock',
        str(arguments.auto_lock),
    ]
    subprocess.Popen(
        command,
        stdout=subprocess.DEVNULL,
        stderr=subprocess.DEVNULL,
        start_new_session=True,
    )


def wait_for_daemon(socket_path, timeout):
    deadline = time.time() + timeout
    while time.time() < deadline:
        try:
            response = daemon_request(socket_path, {'action': 'ping'}, timeout=0.4)
            if response.get('ok'):
                return True
        except Exception:
            time.sleep(0.1)
    return False


def daemon_bw_list_items(domain, state, encoding, password_prompt_invocation):
    for _ in range(2):
        if not state.get('session_key'):
            state['session_key'] = ask_password(password_prompt_invocation)
        process = subprocess.run(
            ['bw', 'list', 'items', '--nointeraction', '--session', state['session_key'], '--url', domain],
            capture_output=True,
        )
        err = process.stderr.decode(encoding).strip()
        if "Vault is locked" in err:
            state['session_key'] = None
            continue
        if process.returncode:
            return []
        out = process.stdout.decode(encoding).strip()
        if not out:
            return []
        return json.loads(out)
    return []


def daemon_bw_get_totp(selection_id, fallback_name, state, encoding, password_prompt_invocation):
    last_error = ''
    lookup_terms = [selection_id]
    if fallback_name and fallback_name not in lookup_terms:
        lookup_terms.append(fallback_name)
    for _ in range(2):
        if not state.get('session_key'):
            state['session_key'] = ask_password(password_prompt_invocation)
        for term in lookup_terms:
            process = subprocess.run(
                ['bw', 'get', 'totp', '--nointeraction', '--session', state['session_key'], term],
                capture_output=True,
            )
            err = process.stderr.decode(encoding).strip()
            if "Vault is locked" in err:
                state['session_key'] = None
                last_error = err
                break
            if process.returncode:
                last_error = err or 'bw get totp failed'
                continue
            code = process.stdout.decode(encoding).strip()
            if code and code != '[]':
                return {'totp': code, 'error': ''}
            last_error = err or 'bw get totp returned empty output'
        else:
            # No lock event in this pass; try a sync+retry.
            subprocess.run(
                ['bw', 'sync', '--nointeraction', '--session', state['session_key']],
                capture_output=True,
            )
            for term in lookup_terms:
                process = subprocess.run(
                    ['bw', 'get', 'totp', '--nointeraction', '--session', state['session_key'], term],
                    capture_output=True,
                )
                if process.returncode == 0:
                    code = process.stdout.decode(encoding).strip()
                    if code and code != '[]':
                        return {'totp': code, 'error': ''}
    return {'totp': '', 'error': last_error}


def daemon_lookup(url, merge_candidates, state, encoding, password_prompt_invocation):
    now = time.time()
    ttl = 120.0
    candidates = []
    for target in resolve_targets(url):
        cached = state['cache'].get(target)
        if cached and now - cached['ts'] <= ttl:
            target_candidates = cached['items']
        else:
            target_candidates = daemon_bw_list_items(target, state, encoding, password_prompt_invocation)
            state['cache'][target] = {'ts': now, 'items': target_candidates}
        if not target_candidates:
            continue
        candidates.extend(target_candidates)
        if not merge_candidates:
            break
    return candidates


def run_daemon(arguments):
    socket_path = daemon_socket_path(arguments.daemon_socket)
    socket_dir = os.path.dirname(socket_path)
    if socket_dir:
        os.makedirs(socket_dir, exist_ok=True)

    if os.path.exists(socket_path):
        try:
            response = daemon_request(socket_path, {'action': 'ping'}, timeout=0.3)
            if response.get('ok'):
                stderr('Daemon already running: {}'.format(socket_path))
                return ExitCodes.SUCCESS
        except Exception:
            os.unlink(socket_path)

    state = {'session_key': None, 'cache': {}, 'last_selection': None}
    server = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
    try:
        server.bind(socket_path)
        os.chmod(socket_path, 0o600)
        server.listen(8)
        running = True
        while running:
            conn, _ = server.accept()
            with conn:
                data = b''
                while b'\n' not in data:
                    chunk = conn.recv(4096)
                    if not chunk:
                        break
                    data += chunk
                if not data:
                    continue
                try:
                    request = json.loads(data.split(b'\n', 1)[0].decode('utf-8'))
                except Exception as error:
                    response = {'ok': False, 'error': 'bad_request', 'detail': str(error)}
                else:
                    action = request.get('action')
                    if action == 'ping':
                        response = {'ok': True}
                    elif action == 'stop':
                        response = {'ok': True}
                        running = False
                    elif action == 'lookup':
                        response = {
                            'ok': True,
                            'candidates': daemon_lookup(
                                request.get('url', ''),
                                bool(request.get('merge_candidates', False)),
                                state,
                                arguments.io_encoding,
                                arguments.password_prompt_invocation,
                            ),
                        }
                    elif action == 'remember_selection':
                        selection_id = request.get('id', '')
                        if selection_id:
                            state['last_selection'] = {
                                'id': selection_id,
                                'name': request.get('name', ''),
                            }
                            response = {'ok': True}
                        else:
                            response = {'ok': False, 'error': 'missing_selection_id'}
                    elif action == 'totp_last':
                        last = state.get('last_selection')
                        if not last:
                            response = {'ok': False, 'error': 'no_last_selection'}
                        else:
                            totp_result = daemon_bw_get_totp(
                                last.get('id', ''),
                                last.get('name', ''),
                                state,
                                arguments.io_encoding,
                                arguments.password_prompt_invocation,
                            )
                            response = {
                                'ok': True,
                                'totp': totp_result.get('totp', ''),
                                'error': totp_result.get('error', ''),
                                'name': last.get('name', ''),
                            }
                    elif action == 'totp':
                        totp_result = daemon_bw_get_totp(
                            request.get('id', ''),
                            request.get('name', ''),
                            state,
                            arguments.io_encoding,
                            arguments.password_prompt_invocation,
                        )
                        response = {
                            'ok': True,
                            'totp': totp_result.get('totp', ''),
                            'error': totp_result.get('error', ''),
                        }
                    else:
                        response = {'ok': False, 'error': 'unknown_action'}
                conn.sendall((json.dumps(response) + '\n').encode('utf-8'))
    finally:
        server.close()
        if os.path.exists(socket_path):
            os.unlink(socket_path)


def fill_credentials_with_dom_watch(username, password, watch_seconds, debug=False):
    js = f"""
(() => {{
  const usernameValue = {json.dumps(username)};
  const passwordValue = {json.dumps(password)};
  const watchMs = Math.max(0, Math.floor({watch_seconds} * 1000));
  const startedAt = Date.now();
  const debug = {str(debug).lower()};
  const log = (...args) => {{
    if (debug) console.info('[qute-bitwarden]', ...args);
  }};

  const usernameSelector = [
    'input[autocomplete="username"]',
    'input[autocomplete="email"]',
    'input[type="email"]',
    'input[name*="user" i]',
    'input[name*="email" i]',
    'input[id*="user" i]',
    'input[id*="email" i]',
    'input[type="text"]'
  ].join(',');

  const passwordSelector = [
    'input[type="password"]',
    'input[autocomplete="current-password"]',
    'input[autocomplete="new-password"]'
  ].join(',');

  const isVisible = (el) => {{
    if (!el) return false;
    const style = window.getComputedStyle(el);
    if (style.visibility === 'hidden' || style.display === 'none') return false;
    if (el.disabled || el.readOnly) return false;
    const rect = el.getBoundingClientRect();
    return rect.width > 0 && rect.height > 0;
  }};

  const firstVisible = (selector) => {{
    for (const el of document.querySelectorAll(selector)) {{
      if (isVisible(el)) return el;
    }}
    return null;
  }};

  const dispatchValue = (el, value) => {{
    if (!el) return;
    el.focus();
    el.value = value;
    el.dispatchEvent(new Event('input', {{ bubbles: true }}));
    el.dispatchEvent(new Event('change', {{ bubbles: true }}));
  }};

  const attemptFill = () => {{
    const userEl = firstVisible(usernameSelector);
    const passEl = firstVisible(passwordSelector);
    log('attemptFill', {{ hasUsername: !!userEl, hasPassword: !!passEl }});

    if (userEl) dispatchValue(userEl, usernameValue);
    if (passEl) dispatchValue(passEl, passwordValue);

    if (passEl || userEl) {{
      (passEl || userEl).focus();
      log('filled');
      return true;
    }}
    return false;
  }};

  if (attemptFill()) return true;
  log('initial attempt failed');
  if (watchMs <= 0) return false;

  let timer = null;
  let quickTimer = null;

  const stop = () => {{
    observer.disconnect();
    if (timer) clearInterval(timer);
    if (quickTimer) clearInterval(quickTimer);
  }};

  const doneOrTimeout = () => {{
    if (attemptFill()) {{
      stop();
      return true;
    }}
    if (Date.now() - startedAt >= watchMs) {{
      stop();
      log('timed out');
      return true;
    }}
    return false;
  }};

  const observer = new MutationObserver(() => {{
    doneOrTimeout();
  }});
  observer.observe(document.documentElement, {{
    subtree: true,
    childList: true,
    attributes: true
  }});

  // Quick burst checks make dynamic forms feel much snappier right after
  // invoking the userscript.
  let burstRuns = 0;
  quickTimer = setInterval(() => {{
    burstRuns += 1;
    if (doneOrTimeout() || burstRuns >= 30) {{
      clearInterval(quickTimer);
      quickTimer = null;
    }}
  }}, 50);

  // Steady-state polling for longer waits.
  timer = setInterval(doneOrTimeout, 100);
  setTimeout(stop, watchMs + 1000);
  log('watching for fields', watchMs, 'ms');
  return false;
}})();
"""
    js_payload = 'eval(atob({}));'.format(json.dumps(base64.b64encode(js.encode('utf-8')).decode('ascii')))
    # jseval expects raw JS expression text; extra quote wrapping turns this
    # into a string literal instead of executing it.
    qute_command('jseval --quiet -- ' + js_payload)



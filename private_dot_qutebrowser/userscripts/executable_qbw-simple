#!/Users/reillyfreret/.qutebrowser-venv/bin/python3

import argparse
import json
import os
import shlex
import socket
import subprocess
import sys
import time
from urllib.parse import urlparse

import pyotp

os.environ['PATH'] = '/opt/homebrew/bin:' + os.environ.get('PATH', '')

SOCKET_PATH = os.path.expanduser("~/.cache/qbw-simple/qbw-simple.sock")
SOCKET_DIR = os.path.dirname(SOCKET_PATH)
IO_ENCODING = "UTF-8"
AUTO_LOCK = 3600
CACHE_TTL_SECONDS = 120
PASSWORD_PROMPT_INVOCATION = (
    "osascript -e "
    '\'Tell application "System Events" to display dialog "Master Password" '
    'default answer "" with hidden answer\' '
    '-e \'text returned of result\''
)


parser = argparse.ArgumentParser(description="Minimal qutebrowser + Bitwarden daemon/client userscript")
parser.add_argument("--daemon", action="store_true", help="Run daemon server")
parser.add_argument("--start-daemon", action="store_true", help="Start daemon and exit")
parser.add_argument("--stop-daemon", action="store_true", help="Stop daemon and exit")
parser.add_argument("--username", action="store_true", help="Insert username for current URL")
parser.add_argument("--password", action="store_true", help="Insert password for current URL")
parser.add_argument("--totp", action="store_true", help="Insert TOTP code for current URL")


def qute_command(command):
    with open(os.environ["QUTE_FIFO"], "w") as fifo:
        fifo.write(command + "\n")
        fifo.flush()


def info(text):
    if "QUTE_FIFO" in os.environ:
        qute_command("message-info " + _quote_qute(text))
    else:
        print(text)


def warn(text):
    if "QUTE_FIFO" in os.environ:
        qute_command("message-warning " + _quote_qute(text))
    else:
        print("WARNING:", text, file=sys.stderr)


def error(text):
    if "QUTE_FIFO" in os.environ:
        qute_command("message-error " + _quote_qute(text))
    else:
        print("ERROR:", text, file=sys.stderr)


def _quote_qute(value):
    safe = value.replace("\r", " ").replace("\n", " ")
    return "'" + safe.replace("'", "'\"'\"'") + "'"


def fake_key_raw(text):
    for character in text:
        sequence = '" "' if character == " " else r"\{}".format(character)
        qute_command("fake-key {}".format(sequence))


def ask_password():
    prompt = subprocess.run(
        shlex.split(PASSWORD_PROMPT_INVOCATION),
        text=True,
        stdout=subprocess.PIPE,
    )
    if prompt.returncode != 0:
        raise RuntimeError("Could not read master password from prompt")
    master_password = prompt.stdout.strip()
    def run_unlock():
        return subprocess.run(
            ["bw", "unlock", "--raw", "--passwordenv", "BW_MASTERPASS"],
            env={**os.environ, "BW_MASTERPASS": master_password},
            text=True,
            stdout=subprocess.PIPE,
            stderr=subprocess.PIPE,
        )

    unlocked = run_unlock()
    if unlocked.returncode == 0:
        return unlocked.stdout.strip()

    stderr_text = unlocked.stderr.strip()
    lowered = stderr_text.lower()

    # Recover from stale local vault state and retry once.
    if "decryption operation failed" in lowered or "expected type" in lowered or "vault is locked" in lowered:
        subprocess.run(["bw", "lock"], capture_output=True, text=True)
        subprocess.run(["bw", "sync"], capture_output=True, text=True)
        unlocked_retry = run_unlock()
        if unlocked_retry.returncode == 0:
            return unlocked_retry.stdout.strip()
        stderr_text = unlocked_retry.stderr.strip()

    raise RuntimeError(
        stderr_text or "Could not unlock Bitwarden vault (check that bw is logged in and password is correct)"
    )


def ensure_session(state):
    now = time.time()
    if state.get("session_key") and now < state.get("session_expires_at", 0):
        return state["session_key"]
    state["session_key"] = ask_password()
    state["session_expires_at"] = now + AUTO_LOCK
    return state["session_key"]


def resolve_targets(url):
    hostname = (urlparse(url).hostname or "").strip().lower()
    if not hostname:
        return []
    targets = [hostname]
    if hostname.startswith("www."):
        targets.append(hostname[4:])
    labels = hostname.split(".")
    if len(labels) >= 2:
        targets.append(".".join(labels[-2:]))
    deduped = []
    for target in targets:
        if target and target not in deduped:
            deduped.append(target)
    return deduped


def bw_list_items_for_target(target, state):
    now = time.time()
    cached = state["cache"].get(target)
    if cached and now - cached["ts"] <= CACHE_TTL_SECONDS:
        return cached["items"]

    for _ in range(2):
        session_key = ensure_session(state)
        process = subprocess.run(
            ["bw", "list", "items", "--nointeraction", "--session", session_key, "--url", target],
            capture_output=True,
        )
        stderr_text = process.stderr.decode(IO_ENCODING).strip()
        lowered = stderr_text.lower()
        if "vault is locked" in lowered or "decryption operation failed" in lowered or "not authenticated" in lowered:
            state["session_key"] = None
            state["session_expires_at"] = 0
            continue
        if process.returncode != 0:
            raise RuntimeError(stderr_text or "bw list items failed")
        stdout_text = process.stdout.decode(IO_ENCODING).strip()
        items = json.loads(stdout_text) if stdout_text else []
        state["cache"][target] = {"ts": now, "items": items}
        return items
    raise RuntimeError("Bitwarden vault is locked")


def get_value_for_url(url, requested_key, state):
    for target in resolve_targets(url):
        items = bw_list_items_for_target(target, state)
        for item in items:
            login = item.get("login") or {}
            if requested_key == "totp":
                raw_totp = login.get("totp")
                if not raw_totp:
                    continue
                if isinstance(raw_totp, str) and raw_totp.startswith("otpauth://"):
                    value = pyotp.parse_uri(raw_totp).now()
                else:
                    value = pyotp.TOTP(str(raw_totp)).now()
            else:
                value = login.get(requested_key)
            if value:
                return value
    return None


def daemon_request(payload, timeout=10.0):
    with socket.socket(socket.AF_UNIX, socket.SOCK_STREAM) as client:
        client.settimeout(timeout)
        client.connect(SOCKET_PATH)
        client.sendall((json.dumps(payload) + "\n").encode("utf-8"))
        data = b""
        while b"\n" not in data:
            chunk = client.recv(4096)
            if not chunk:
                break
            data += chunk
    if not data:
        raise RuntimeError("Empty response from daemon")
    return json.loads(data.split(b"\n", 1)[0].decode("utf-8"))


def run_daemon():
    os.makedirs(SOCKET_DIR, exist_ok=True)

    if os.path.exists(SOCKET_PATH):
        try:
            response = daemon_request({"action": "ping"}, timeout=0.5)
            if response.get("ok"):
                print("Daemon already running", file=sys.stderr)
                return 0
        except Exception:
            os.unlink(SOCKET_PATH)

    state = {"session_key": None, "session_expires_at": 0, "cache": {}}
    server = socket.socket(socket.AF_UNIX, socket.SOCK_STREAM)
    try:
        server.bind(SOCKET_PATH)
        os.chmod(SOCKET_PATH, 0o600)
        server.listen(8)
        running = True
        while running:
            conn, _ = server.accept()
            with conn:
                raw = b""
                while b"\n" not in raw:
                    chunk = conn.recv(4096)
                    if not chunk:
                        break
                    raw += chunk
                if not raw:
                    continue
                try:
                    request = json.loads(raw.split(b"\n", 1)[0].decode("utf-8"))
                    action = request.get("action")
                    if action == "ping":
                        response = {"ok": True}
                    elif action == "stop":
                        response = {"ok": True}
                        running = False
                    elif action == "get_value":
                        url = request.get("url", "")
                        key = request.get("key", "")
                        if key not in {"username", "password", "totp"}:
                            response = {"ok": False, "error": "invalid_key"}
                        else:
                            value = get_value_for_url(url, key, state)
                            if value:
                                response = {"ok": True, "value": value}
                            else:
                                response = {"ok": False, "error": "no_value"}
                    else:
                        response = {"ok": False, "error": "unknown_action"}
                except Exception as exc:
                    response = {"ok": False, "error": "exception", "detail": str(exc)}
                conn.sendall((json.dumps(response) + "\n").encode("utf-8"))
    finally:
        server.close()
        if os.path.exists(SOCKET_PATH):
            os.unlink(SOCKET_PATH)
    return 0


def start_daemon():
    command = [sys.executable, os.path.abspath(__file__), "--daemon"]
    subprocess.Popen(command, stdout=subprocess.DEVNULL, stderr=subprocess.DEVNULL, start_new_session=True)
    deadline = time.time() + 3.0
    while time.time() < deadline:
        try:
            response = daemon_request({"action": "ping"}, timeout=0.5)
            if response.get("ok"):
                info("qbw-simple daemon started")
                return 0
        except Exception:
            time.sleep(0.1)
    error("Could not start qbw-simple daemon")
    return 1


def stop_daemon():
    try:
        daemon_request({"action": "stop"}, timeout=1.0)
        info("qbw-simple daemon stopped")
        return 0
    except Exception as exc:
        error("Could not stop daemon: {}".format(exc))
        return 1


def run_client(args):
    if not (args.username or args.password or args.totp):
        error("Specify exactly one of --username, --password, or --totp")
        return 1
    selected = [args.username, args.password, args.totp]
    if sum(1 for flag in selected if flag) != 1:
        error("Specify only one of --username, --password, or --totp")
        return 1

    url = os.getenv("QUTE_URL", "")
    if not url:
        error("QUTE_URL is not set")
        return 1

    if args.username:
        key = "username"
    elif args.password:
        key = "password"
    else:
        key = "totp"
    try:
        response = daemon_request({"action": "get_value", "url": url, "key": key}, timeout=30.0)
    except Exception as exc:
        error("Daemon request failed (start it with --start-daemon): {}".format(exc))
        return 1

    if response.get("ok"):
        fake_key_raw(response.get("value", ""))
        return 0

    err = response.get("error")
    if err == "no_value":
        warn("No {} value found for this site".format(key))
        return 1
    if err == "invalid_key":
        error("Invalid requested key")
        return 1

    detail = response.get("detail")
    if detail:
        error("Daemon error: {} ({})".format(err, detail))
    else:
        error("Daemon error: {}".format(err))
    return 1


def main():
    args = parser.parse_args()
    if args.daemon:
        return run_daemon()
    if args.start_daemon:
        return start_daemon()
    if args.stop_daemon:
        return stop_daemon()
    return run_client(args)


if __name__ == "__main__":
    sys.exit(main())
